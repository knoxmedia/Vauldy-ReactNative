{
  "name": "vauldy-react-native",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:go": "expo start --go",
    "android": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/with-android-env.ps1 run:android",
    "ios": "expo run:ios",
    "prebuild": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/with-android-env.ps1 prebuild",
    "apk:release": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-release-apk.ps1 -Arch arm64-v8a",
    "apk:release:arm64": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-release-apk.ps1 -Arch arm64-v8a",
    "apk:release:armv7": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-release-apk.ps1 -Arch armeabi-v7a",
    "apk:release:all": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-release-apk.ps1 -Arch all",
    "apk:install": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-release-apk.ps1 -Arch arm64-v8a -Install",
    "typecheck": "tsc --noEmit",
    "generate:icons": "node scripts/generate-adaptive-icon.mjs",
    "postinstall": "node scripts/embed-pdfjs.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "@expo/vector-icons": "~14.0.4",
    "@react-native-async-storage/async-storage": "1.23.1",
    "axios": "^1.7.9",
    "expo": "~52.0.46",
    "expo-asset": "~11.0.5",
    "expo-av": "~15.0.2",
    "expo-constants": "~17.0.8",
    "expo-font": "~13.0.4",
    "expo-image": "~2.0.7",
    "expo-keep-awake": "~14.0.3",
    "expo-linear-gradient": "~14.0.2",
    "expo-linking": "~7.0.5",
    "expo-router": "~4.0.20",
    "expo-screen-orientation": "~8.0.4",
    "expo-secure-store": "~14.0.1",
    "expo-splash-screen": "~0.29.24",
    "expo-status-bar": "~2.0.1",
    "pdfjs-dist": "^3.11.174",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "~0.19.13",
    "react-native-webview": "13.12.5",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/react": "~18.3.12",
    "typescript": "~5.3.3",
    "vitest": "^2.1.9"
  }
}
